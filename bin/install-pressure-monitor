#!/usr/bin/env bash
set -euo pipefail

ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="com.lumiwealth.cmux-pressure-monitor"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
RUNTIME="$HOME/Library/Application Support/cmux-agent-recovery"
LOG_DIR="$HOME/Library/Logs/cmux-agent-recovery"
UID_VALUE="$(id -u)"

mkdir -p "$HOME/Library/LaunchAgents" "$LOG_DIR" "$RUNTIME/bin" "$RUNTIME/sql" "$RUNTIME/state"
cp "$ROOT/bin/cmux-recovery" "$RUNTIME/bin/cmux-recovery"
cp "$ROOT/sql/schema.sql" "$RUNTIME/sql/schema.sql"
chmod +x "$RUNTIME/bin/cmux-recovery"

cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>CMUX_RECOVERY_DB="$RUNTIME/state/cmux-recovery.sqlite" CMUX_RECOVERY_DEBUG_DIR="$LOG_DIR" "$RUNTIME/bin/cmux-recovery" pressure --notify --quiet &gt;/dev/null 2&gt;&gt;$LOG_DIR/pressure-monitor.err.log || true</string>
  </array>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$LOG_DIR/pressure-monitor.out.log</string>
  <key>StandardErrorPath</key>
  <string>$LOG_DIR/pressure-monitor.err.log</string>
</dict>
</plist>
PLIST

launchctl bootout "gui/$UID_VALUE" "$PLIST" >/dev/null 2>&1 || true
launchctl bootstrap "gui/$UID_VALUE" "$PLIST"
launchctl enable "gui/$UID_VALUE/$LABEL"
launchctl kickstart -k "gui/$UID_VALUE/$LABEL" >/dev/null 2>&1 || true

echo "installed: $PLIST"
echo "runtime: $RUNTIME"
echo "logs: $LOG_DIR/pressure-monitor.err.log"
