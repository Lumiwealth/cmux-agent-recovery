}
GENERIC_WORKSPACE_TITLES = {
    "development",
    "documents development",
    "users robertgrzesik development",
    "users robertgrzesik documents development",
}
SESSION_ID_RE = re.compile(
    r"\b(?:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}|[0-9a-f]{8,}-[0-9a-f-]{20,})\b",
    re.IGNORECASE,
)
SCREEN_RESUME_RE = re.compile(
    r"\b(?P<tool>codex|claude)\b(?:\s+-C\s+\S+)?\s+(?:resume|--resume)\s+(?P<session_id>[0-9a-f][0-9a-f-]{20,})\b",
    re.IGNORECASE,
)
SCREEN_SCROLLBACK_LINES = 2400
SCREEN_TRANSCRIPT_SCAN_LIMIT = 300
GENERIC_FALLBACK_AUTO_SELECT_GAP_SECONDS = 10 * 60
GENERIC_FALLBACK_AUTO_SELECT_MAX_AGE_SECONDS = 2 * 60 * 60


def utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_time(value: str | None) -> float:
    if not value:
        return 0.0
    raw = value.strip()
    if not raw:
        return 0.0
    try:
        if raw.endswith("Z"):
            raw = raw[:-1] + "+00:00"
        return dt.datetime.fromisoformat(raw).timestamp()
    except ValueError:
        return 0.0


def normalize_title(value: str | None) -> str:
    text = (value or "").strip()
    text = re.sub(r"(?<=[a-z0-9])(?=[A-Z])", " ", text)
    text = text.lower()
    text = re.sub(r"\blinked\s+in\b", "linkedin", text)
    text = re.sub(r"\s+", " ", text)
    text = re.sub(r"[^0-9a-z]+", " ", text)
    return re.sub(r"\s+", " ", text).strip()


def title_match_keys(value: str | None) -> set[str]:
    normalized = normalize_title(value)
    if not normalized:
        return set()
    return {normalized}


def title_matches(current_title: str | None, candidate_title: str | None, candidate_workspace_title: str | None = None) -> bool:
    current_keys = title_match_keys(current_title)
    candidate_keys = title_match_keys(candidate_title) | title_match_keys(candidate_workspace_title)
    return bool(current_keys and candidate_keys and current_keys & candidate_keys)


def generic_workspace_title(value: str | None) -> bool:
    return normalize_title(value) in GENERIC_WORKSPACE_TITLES


def candidate_has_title(candidate: dict[str, Any] | sqlite3.Row) -> bool:
    return bool(title_match_keys(candidate["normalized_title"]) | title_match_keys(candidate["workspace_title"]))


def generic_workspace_fallback_match(current: dict[str, Any], candidate: dict[str, Any] | sqlite3.Row) -> bool:
    if candidate["tool"] != "codex":
        return False
    if not generic_workspace_title(current.get("normalized_title") or current.get("workspace_title")):
        return False
    if candidate_has_title(candidate):
        return False
    cwd_match = same_path(current.get("current_directory"), candidate["cwd"])
    resume_cwd = candidate_cwd(dict(candidate))
    resume_cwd_match = same_path(current.get("current_directory"), str(resume_cwd))
    if not (cwd_match or resume_cwd_match):
        return False
    age = max(0.0, time.time() - parse_time(candidate["last_seen"]))
    return age < 7 * 24 * 60 * 60


def untitled_topic_fallback_match(current: dict[str, Any], candidate: dict[str, Any] | sqlite3.Row) -> bool:
    if candidate["tool"] != "codex":
        return False
    if generic_workspace_title(current.get("normalized_title") or current.get("workspace_title")):
        return False
    if candidate_has_title(candidate):
        return False
    cwd_match = same_path(current.get("current_directory"), candidate["cwd"])
    resume_cwd = candidate_cwd(dict(candidate))
    resume_cwd_match = same_path(current.get("current_directory"), str(resume_cwd))
    if not (cwd_match or resume_cwd_match):
        return False
    age = max(0.0, time.time() - parse_time(candidate["last_seen"]))
    if age >= 7 * 24 * 60 * 60:
        return False
    try:
        payload = json.loads(str(candidate["payload_json"] or "{}"))
    except json.JSONDecodeError:
        payload = {}
    text = " ".join(part for part in [str(candidate["process_title"] or ""), payload_value_text(payload)] if part)
    hits = topic_hits_for_title(current.get("workspace_title") or current.get("normalized_title"), text)
    return substantial_topic_hits(hits)


def screen_resume_title_allowed(current: dict[str, Any], item: dict[str, Any]) -> bool:
    if not current.get("normalized_title"):
        return True
    if not candidate_has_title(item):
        return False
    return title_matches(current.get("normalized_title"), item.get("normalized_title"), item.get("workspace_title"))


def title_terms(value: str | None) -> list[str]:
    terms: list[str] = []
    seen: set[str] = set()
    for term in normalize_title(value).split():
        if len(term) < 3 or term in TITLE_STOPWORDS:
            continue
        if term not in seen:
            seen.add(term)
            terms.append(term)
    return terms


def title_topic_signals(value: str | None) -> list[str]:
    normalized = normalize_title(value)
    tokens = normalized.split()
    skip_terms: set[str] = set()
    signals: list[str] = []
    seen: set[str] = set()

    def add(signal: str) -> None:
        key = normalize_title(signal)
        if not key or key in seen:
            return
        seen.add(key)
        signals.append(key)

    if "post hog" in normalized:
        skip_terms.update({"post", "hog"})
        add("post hog")
        add("posthog")
        if "recordings" in tokens or "recording" in tokens:
            add("posthog recordings")
            add("post hog recordings")

    for term in title_terms(value):
        if term in skip_terms:
            continue
        add(term)

    for index, token in enumerate(tokens[:-1]):
        if len(token) < 3 or token in TITLE_STOPWORDS:
            continue
        next_token = tokens[index + 1]
        if len(next_token) == 1 and next_token not in TITLE_STOPWORDS:
            add(f"{token} {next_token}")

    token_set = set(tokens)
    if {"how", "found"} <= token_set:
        add("how found")
        add("how found us")
        add("howfoundus")
    if "new" in token_set and ({"lead"} & token_set or {"leads"} & token_set):
        add("new lead")
        add("new leads")
        add("lead created")
        add("leadcreated")

    return signals


def substantial_topic_hits(hits: list[str]) -> bool:
    return len(hits) >= 2 or any(len(hit.split()) > 1 for hit in hits)


def topic_hits_for_title(title: str | None, text: str | None) -> list[str]:
    normalized_text = normalize_title(text)
    if not normalized_text:
        return []
    hits: list[str] = []
    for signal in title_topic_signals(title):
        words = signal.split()
        if not words:
            continue
        if len(words) > 1:
            pattern = r"\b" + r"\s+".join(re.escape(word) for word in words) + r"\b"
        else:
            pattern = rf"\b{re.escape(words[0])}[a-z0-9]*\b"
        if re.search(pattern, normalized_text):
            hits.append(signal)
    return hits


def clean(value: Any) -> str | None:
    if value is None:
        return None
    text = str(value).strip()
    return text or None


def same_path(left: str | None, right: str | None) -> bool:
    if not left or not right:
        return False
    return str(Path(left).expanduser()) == str(Path(right).expanduser())


def path_variants(value: str | Path | None) -> list[Path]:
    variants: list[Path] = []
    if not value:
        return variants
    raw = Path(value).expanduser()
    variants.append(raw)
    parts = raw.parts
    old_root = ("/", "Users", "robertgrzesik", "Documents", "Development")
    if parts[: len(old_root)] == old_root:
        variants.append(Path("/Users/robertgrzesik/Development", *parts[len(old_root) :]))
    new_root = ("/", "Users", "robertgrzesik", "Development")
    if parts[: len(new_root)] == new_root:
        variants.append(Path("/Users/robertgrzesik/Documents/Development", *parts[len(new_root) :]))
    seen: set[str] = set()
    out: list[Path] = []
    for item in variants:
        key = str(item)
        if key not in seen:
            seen.add(key)
            out.append(item)
    return out


def claude_project_slug(path: Path) -> str:
    parts = path.expanduser().parts
    if not parts:
        return ""
    if parts[0] == "/":
        return "-" + "-".join(parts[1:])
    return "-".join(parts)


def file_observed_at(path: Path) -> str:
    try:
        timestamp = path.stat().st_mtime
    except OSError:
        return utc_now()
    return dt.datetime.fromtimestamp(timestamp, dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def int_or_none(value: Any) -> int | None:
    try:
        if value is None or str(value).strip() == "":
            return None
        return int(str(value).strip())
    except (TypeError, ValueError):
        return None


def tool_from_label(value: str | None) -> str | None:
    text = (value or "").strip().lower()
    if not text:
        return None
    if "codex" in text:
        return "codex"
    if "claude" in text:
        return "claude"
    return None


def extract_session_id(value: str | None) -> str | None:
    if not value:
        return None
    match = SESSION_ID_RE.search(value)
    return match.group(0) if match else None


def db_path() -> Path:
    return Path(os.environ.get("CMUX_RECOVERY_DB", str(DEFAULT_DB))).expanduser()


def default_report_dirs() -> list[Path]:
    raw = os.environ.get("CMUX_RECOVERY_REPORT_DIRS", "")
    return [Path(item).expanduser() for item in raw.split(os.pathsep) if item.strip()]


def connect_db() -> sqlite3.Connection:
    path = db_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    con = sqlite3.connect(path, timeout=10.0)
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA busy_timeout = 10000")
    with SCHEMA.open("r", encoding="utf-8") as f:
        con.executescript(f.read())
    ensure_schema_columns(con)
    return con


def ensure_schema_columns(con: sqlite3.Connection) -> None:
    required = {
        "memory_workspace_samples": {
            "total_pcpu": "REAL NOT NULL DEFAULT 0",
        },
        "memory_process_samples": {
            "pcpu": "REAL NOT NULL DEFAULT 0",
        },
    }
    for table, columns in required.items():
        existing = {row["name"] for row in con.execute(f"PRAGMA table_info({table})")}
        for name, definition in columns.items():
            if name not in existing:
                con.execute(f"ALTER TABLE {table} ADD COLUMN {name} {definition}")


def cmux_bin() -> str:
    override = os.environ.get("CMUX_BIN")
    if override:
        return str(Path(override).expanduser())
    if DEFAULT_CMUX_BIN.exists():
        return str(DEFAULT_CMUX_BIN)
    return "cmux"


def run_cmux(args: list[str], timeout: float = 2.0) -> str | None:
    try:
        proc = subprocess.run(
            [cmux_bin(), *args],
            text=True,
            capture_output=True,
            timeout=timeout,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout


def run_cmux_json(args: list[str], timeout: float = 2.0) -> dict[str, Any] | list[Any] | None:
    out = run_cmux(args, timeout=timeout)
    if not out:
        return None
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return None


def saved_session_path() -> Path:
    return Path.home() / "Library/Application Support/cmux/session-com.cmuxterm.app.json"


def saved_session_workspaces() -> list[dict[str, Any]]:
    if os.environ.get("CMUX_RECOVERY_DISABLE_SAVED_SESSION", "").strip().lower() in {"1", "true", "yes", "on"}:
        return []
    path = saved_session_path()
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return []
    rows: list[dict[str, Any]] = []
    for window in data.get("windows", []) or []:
        tab_manager = window.get("tabManager") or {}
        for index, ws in enumerate(tab_manager.get("workspaces", []) or []):
            rows.append(
                {
                    "index": index,
                    "title": clean(ws.get("customTitle")) or clean(ws.get("processTitle")),
                    "current_directory": clean(ws.get("currentDirectory")),
                    "process_title": clean(ws.get("processTitle")),
                    "focused_panel_id": clean(ws.get("focusedPanelId")),
                    "panels": ws.get("panels") or [],
                }
            )
    return rows


def selected_surface(pane: dict[str, Any]) -> dict[str, Any] | None:
    surfaces = pane.get("surfaces") or []
    if not surfaces:
        return None
    selected_id = clean(pane.get("selected_surface_id"))
    selected_ref = clean(pane.get("selected_surface_ref"))
    for surface in surfaces:
        if surface.get("selected") is True:
            return surface
    for surface in surfaces:
        if clean(surface.get("id")) == selected_id or clean(surface.get("ref")) == selected_ref:
            return surface
    return surfaces[0]


def tree_workspaces() -> list[dict[str, Any]]:
    tree = run_cmux_json(["--id-format", "both", "tree", "--all", "--json"], timeout=4.0)
    if not isinstance(tree, dict):
        return []

    saved = saved_session_workspaces()
    out: list[dict[str, Any]] = []
    for window in tree.get("windows", []) or []:
        for ws in window.get("workspaces", []) or []:
            pane = None
            surface = None
            for candidate in ws.get("panes", []) or []:
                pane = candidate
                surface = selected_surface(candidate)
                if candidate.get("focused") or candidate.get("active"):
                    break

            workspace_index = ws.get("index")
            title = clean(ws.get("title"))
            saved_match = None
            for row in saved:
                if row.get("index") == workspace_index:
                    saved_match = row
                    break
            if saved_match is None:
                norm = normalize_title(title)
                saved_match = next((row for row in saved if normalize_title(row.get("title")) == norm), None)

            panel_match = None
            if saved_match and surface:
                sid = clean(surface.get("id"))
                for panel in saved_match.get("panels") or []:
                    if clean(panel.get("id")) == sid:
                        panel_match = panel
                        break

            out.append(
                {
                    "window_id": clean(window.get("id")),
                    "window_ref": clean(window.get("ref")),
                    "workspace_id": clean(ws.get("id")),
                    "workspace_ref": clean(ws.get("ref")),
                    "workspace_index": workspace_index,
                    "workspace_title": title,
                    "workspace_description": clean(ws.get("description")),
                    "normalized_title": normalize_title(title),
                    "current_directory": clean((saved_match or {}).get("current_directory")),
                    "process_title": clean((saved_match or {}).get("process_title")),
                    "selected": 1 if ws.get("selected") else 0,
                    "active": 1 if ws.get("active") else 0,
                    "pinned": 1 if ws.get("pinned") else 0,
                    "pane_id": clean((pane or {}).get("id")),
                    "pane_ref": clean((pane or {}).get("ref")),
                    "surface_id": clean((surface or {}).get("id")),
                    "surface_ref": clean((surface or {}).get("ref")),
                    "surface_index": (surface or {}).get("index"),
                    "surface_title": clean((surface or {}).get("title")) or clean((panel_match or {}).get("title")),
                    "tty": clean((surface or {}).get("tty")) or clean((panel_match or {}).get("ttyName")),
                    "snapshot_json": json.dumps(ws, separators=(",", ":"), ensure_ascii=False),
                }
            )
    return out


def identify_current() -> dict[str, Any]:
    identity = run_cmux_json(["--id-format", "both", "identify"], timeout=2.0)
    current: dict[str, Any] = {}
    if isinstance(identity, dict):
        current = identity.get("caller") or identity.get("focused") or {}
    env = os.environ
    return {
        "workspace_id": clean(current.get("workspace_id") or current.get("workspaceId") or env.get("CMUX_WORKSPACE_ID")),
        "workspace_ref": clean(current.get("workspace_ref") or env.get("CMUX_WORKSPACE_REF")),
        "surface_id": clean(current.get("surface_id") or current.get("surfaceId") or env.get("CMUX_SURFACE_ID")),
        "surface_ref": clean(current.get("surface_ref")),
        "tab_id": clean(current.get("tab_id") or current.get("tabId") or env.get("CMUX_TAB_ID")),
        "pane_id": clean(current.get("pane_id") or current.get("paneId") or env.get("CMUX_PANE_ID")),
        "pane_ref": clean(current.get("pane_ref")),
    }


def current_workspace() -> dict[str, Any]:
    ident = identify_current()
    workspaces = tree_workspaces()
    for ws in workspaces:
        if ident.get("surface_id") and ws.get("surface_id") == ident.get("surface_id"):
            return {**ws, **{k: v for k, v in ident.items() if v}}
        if ident.get("workspace_id") and ws.get("workspace_id") == ident.get("workspace_id"):
            return {**ws, **{k: v for k, v in ident.items() if v}}
        if ident.get("workspace_ref") and ws.get("workspace_ref") == ident.get("workspace_ref"):
            return {**ws, **{k: v for k, v in ident.items() if v}}
    selected = next((ws for ws in workspaces if ws.get("selected")), None)
    if selected:
        return {**selected, **{k: v for k, v in ident.items() if v}}
    return {k: v for k, v in ident.items() if v}


def read_screen_text(current: dict[str, Any], *, lines: int = SCREEN_SCROLLBACK_LINES) -> str:
    workspace = current.get("workspace_id") or current.get("workspace_ref")
    surface = current.get("surface_id") or current.get("surface_ref")
    if not workspace or not surface:
        return ""
    out = run_cmux(
        [
            "read-screen",
            "--workspace",
            str(workspace),
            "--surface",
            str(surface),
            "--scrollback",
            "--lines",
            str(lines),
        ],
        timeout=3.0,
    )
    return out or ""


def screen_resume_refs_from_text(out: str) -> list[dict[str, str]]:
    if not out:
        return []
    refs: list[dict[str, str]] = []
    seen: set[tuple[str, str]] = set()
    for match in SCREEN_RESUME_RE.finditer(out):
        tool = match.group("tool").lower()
        session_id = match.group("session_id")
        key = (tool, session_id)
        if key in seen:
            refs = [item for item in refs if (item["tool"], item["session_id"]) != key]
        seen.add(key)
        refs.append({"tool": tool, "session_id": session_id})
    refs.reverse()
    return refs[:1]


def screen_resume_refs(current: dict[str, Any]) -> list[dict[str, str]]:
    return screen_resume_refs_from_text(read_screen_text(current))


def insert_workspace_observations(con: sqlite3.Connection, source: str, rows: list[dict[str, Any]] | None = None) -> None:
    observed_at = utc_now()
    for row in rows if rows is not None else tree_workspaces():
        con.execute(
            """
            INSERT INTO observed_workspaces (
              observed_at, source, window_id, window_ref, workspace_id, workspace_ref,
              workspace_index, workspace_title, normalized_title, current_directory,
              process_title, selected, active, pinned, pane_id, pane_ref, surface_id,
              surface_ref, surface_index, surface_title, tty, snapshot_json
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                observed_at,
                source,
                row.get("window_id"),
                row.get("window_ref"),
                row.get("workspace_id"),
                row.get("workspace_ref"),
                row.get("workspace_index"),
                row.get("workspace_title"),
                row.get("normalized_title"),
                row.get("current_directory"),
                row.get("process_title"),
                int(row.get("selected") or 0),
                int(row.get("active") or 0),
                int(row.get("pinned") or 0),
                row.get("pane_id"),
                row.get("pane_ref"),
                row.get("surface_id"),
                row.get("surface_ref"),
                row.get("surface_index"),
                row.get("surface_title"),
                row.get("tty"),
                row.get("snapshot_json"),
            ),
        )


def memory_enabled() -> bool:
    value = os.environ.get("CMUX_RECOVERY_DISABLE_MEMORY", "").strip().lower()
    return value not in {"1", "true", "yes", "on"}


def collect_processes() -> list[dict[str, Any]]:
    fixture = os.environ.get("CMUX_RECOVERY_PS_JSON")
    if fixture:
        try:
            raw = json.loads(fixture)
            return [dict(row) for row in raw if isinstance(row, dict)]
        except json.JSONDecodeError:
            return []
    try:
        proc = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,pgid=,tty=,rss=,pmem=,pcpu=,comm="],
            text=True,
            capture_output=True,
            timeout=2.0,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return []
    if proc.returncode != 0:
        return []
    rows: list[dict[str, Any]] = []
    for line in proc.stdout.splitlines():
        parts = line.strip().split(None, 7)
        if len(parts) < 8:
            continue
        pid, ppid, pgid, tty, rss, pmem, pcpu, command = parts
        rows.append(
            {
                "pid": int_or_none(pid),
                "ppid": int_or_none(ppid),
                "pgid": int_or_none(pgid),
                "tty": None if tty == "??" else tty,
                "rss_kb": int_or_none(rss) or 0,
                "pmem": float(pmem) if re.match(r"^\d+(?:\.\d+)?$", pmem) else 0.0,
                "pcpu": float(pcpu) if re.match(r"^\d+(?:\.\d+)?$", pcpu) else 0.0,
                "command_name": Path(command).name,
            }
        )
    return [row for row in rows if row.get("pid") is not None]


def process_tree_for_tty(processes: list[dict[str, Any]], tty: str | None) -> list[dict[str, Any]]:
    if not tty:
        return []
    by_pid = {int(row["pid"]): row for row in processes if row.get("pid") is not None}
    children: dict[int, list[int]] = {}
    for row in processes:
        pid = row.get("pid")
        ppid = row.get("ppid")
        if pid is None or ppid is None:
            continue
        children.setdefault(int(ppid), []).append(int(pid))
    roots = [int(row["pid"]) for row in processes if row.get("tty") == tty and row.get("pid") is not None]
    seen: set[int] = set()
    out: list[dict[str, Any]] = []
    stack = [(pid, 0, True) for pid in roots]
    while stack:
        pid, depth, is_tty_attached = stack.pop()
        if pid in seen:
            continue
        seen.add(pid)
        row = by_pid.get(pid)
        if not row:
            continue
        out.append({**row, "depth": depth, "is_tty_attached": 1 if is_tty_attached else 0})
        for child in children.get(pid, []):
            stack.append((child, depth + 1, False))
    out.sort(key=lambda row: (int(row.get("rss_kb") or 0), int(row.get("pid") or 0)), reverse=True)
    return out


def record_memory_snapshot(
    con: sqlite3.Connection,
    source: str,
    rows: list[dict[str, Any]] | None = None,
    *,
    force: bool = False,
) -> list[dict[str, Any]]:
    if not force and not memory_enabled():
        return []
    observed_at = utc_now()
    workspaces = rows if rows is not None else tree_workspaces()
    processes = collect_processes()
    samples: list[dict[str, Any]] = []
    for ws in workspaces:
        tree = process_tree_for_tty(processes, ws.get("tty"))
        total_rss = sum(int(row.get("rss_kb") or 0) for row in tree)
        total_pmem = sum(float(row.get("pmem") or 0.0) for row in tree)
        total_pcpu = sum(float(row.get("pcpu") or 0.0) for row in tree)
        top = [
            {
                "pid": row.get("pid"),
                "name": row.get("command_name"),
                "rss_kb": row.get("rss_kb"),
                "pmem": row.get("pmem"),
                "pcpu": row.get("pcpu"),
            }
            for row in tree[:8]
        ]
        cursor = con.execute(
            """
            INSERT INTO memory_workspace_samples (
              observed_at, source, window_id, window_ref, workspace_id, workspace_ref,
              workspace_index, workspace_title, normalized_title, surface_id, surface_ref,
              tty, process_count, total_rss_kb, total_pmem, total_pcpu, top_processes_json
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                observed_at,
                source,
                ws.get("window_id"),
                ws.get("window_ref"),
                ws.get("workspace_id"),
                ws.get("workspace_ref"),
                ws.get("workspace_index"),
                ws.get("workspace_title"),
                ws.get("normalized_title"),
                ws.get("surface_id"),
                ws.get("surface_ref"),
                ws.get("tty"),
                len(tree),
                total_rss,
                total_pmem,
                total_pcpu,
                json.dumps(top, separators=(",", ":"), ensure_ascii=False),
            ),
        )
        sample_id = int(cursor.lastrowid)
        for row in tree:
            con.execute(
                """
                INSERT INTO memory_process_samples (
                  sample_id, pid, ppid, pgid, tty, rss_kb, pmem, pcpu, command_name,
                  depth, is_tty_attached
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    sample_id,
                    row.get("pid"),
                    row.get("ppid"),
                    row.get("pgid"),
                    row.get("tty"),
                    int(row.get("rss_kb") or 0),
                    float(row.get("pmem") or 0.0),
                    float(row.get("pcpu") or 0.0),
                    row.get("command_name"),
                    row.get("depth"),
                    int(row.get("is_tty_attached") or 0),
                ),
            )
        samples.append({**ws, "sample_id": sample_id, "process_count": len(tree), "total_rss_kb": total_rss, "total_pmem": total_pmem, "total_pcpu": total_pcpu, "top_processes": top})
    return samples


def event_from_payload(payload: dict[str, Any], args: argparse.Namespace, workspace: dict[str, Any]) -> dict[str, Any]:
    tool = args.tool
    event = args.event or payload.get("hook_event_name") or "unknown"
    session_id = (
        payload.get("session_id")
        or payload.get("sessionId")
        or payload.get("conversation_id")
        or payload.get("conversationId")
        or payload.get("thread_id")
        or payload.get("threadId")
        or payload.get("id")
    )
    return {
        "observed_at": utc_now(),
        "tool": tool,
        "event": str(event),
        "source": args.source or f"{tool}-hook",
        "session_id": clean(session_id),
        "turn_id": clean(payload.get("turn_id") or payload.get("turnId")),
        "cwd": clean(args.cwd or payload.get("cwd") or payload.get("current_directory") or payload.get("currentDirectory")),
        "transcript_path": clean(payload.get("transcript_path") or payload.get("transcriptPath")),
        "model": clean(payload.get("model")),
        "permission_mode": clean(payload.get("permission_mode") or payload.get("permissionMode") or payload.get("approval_mode") or payload.get("approvalMode")),
        "workspace_title": clean(workspace.get("workspace_title")) or clean(os.environ.get("CMUX_WORKSPACE_NAME")),
        "normalized_title": normalize_title(clean(workspace.get("workspace_title")) or clean(os.environ.get("CMUX_WORKSPACE_NAME"))),
        "workspace_id": clean(workspace.get("workspace_id")),
        "workspace_ref": clean(workspace.get("workspace_ref")),
        "workspace_index": workspace.get("workspace_index"),
        "surface_id": clean(workspace.get("surface_id")),
        "surface_ref": clean(workspace.get("surface_ref")),
        "tab_id": clean(workspace.get("tab_id")),
        "pane_id": clean(workspace.get("pane_id")),
        "process_title": clean(workspace.get("process_title")),
        "tty": clean(workspace.get("tty")),
        "payload_json": json.dumps(payload, separators=(",", ":"), ensure_ascii=False),
    }


def upsert_event(con: sqlite3.Connection, row: dict[str, Any]) -> None:
    con.execute(
        """
        INSERT INTO agent_events (
          observed_at, tool, event, source, session_id, turn_id, cwd, transcript_path,
          model, permission_mode, workspace_title, normalized_title, workspace_id,
          workspace_ref, workspace_index, surface_id, surface_ref, tab_id, pane_id,
          process_title, tty, payload_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        tuple(row.get(k) for k in [
            "observed_at", "tool", "event", "source", "session_id", "turn_id", "cwd",
            "transcript_path", "model", "permission_mode", "workspace_title",
            "normalized_title", "workspace_id", "workspace_ref", "workspace_index",
            "surface_id", "surface_ref", "tab_id", "pane_id", "process_title", "tty",
            "payload_json",
        ]),
    )
    if not row.get("session_id"):
        return
    existing = con.execute(
        """
        SELECT 1 FROM session_bindings
        WHERE tool = ? AND session_id = ?
        """,
        (row["tool"], row["session_id"]),
    ).fetchone()
    if existing and str(row.get("event") or "") == "SessionStart":
        return
    con.execute(
        """
        INSERT INTO session_bindings (
          tool, session_id, first_seen, last_seen, last_event, last_source, cwd,
          transcript_path, model, permission_mode, workspace_title, normalized_title,
          workspace_id, workspace_ref, workspace_index, surface_id, surface_ref,
          tab_id, pane_id, process_title, tty, payload_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(tool, session_id) DO UPDATE SET
          last_seen=excluded.last_seen,
          last_event=excluded.last_event,
          last_source=excluded.last_source,
          cwd=COALESCE(NULLIF(excluded.cwd, ''), session_bindings.cwd),
          transcript_path=COALESCE(NULLIF(excluded.transcript_path, ''), session_bindings.transcript_path),
          model=COALESCE(NULLIF(excluded.model, ''), session_bindings.model),
          permission_mode=COALESCE(NULLIF(excluded.permission_mode, ''), session_bindings.permission_mode),
          workspace_title=COALESCE(NULLIF(excluded.workspace_title, ''), session_bindings.workspace_title),
          normalized_title=COALESCE(NULLIF(excluded.normalized_title, ''), session_bindings.normalized_title),
          workspace_id=COALESCE(NULLIF(excluded.workspace_id, ''), session_bindings.workspace_id),
          workspace_ref=COALESCE(NULLIF(excluded.workspace_ref, ''), session_bindings.workspace_ref),
          workspace_index=COALESCE(excluded.workspace_index, session_bindings.workspace_index),
          surface_id=COALESCE(NULLIF(excluded.surface_id, ''), session_bindings.surface_id),
          surface_ref=COALESCE(NULLIF(excluded.surface_ref, ''), session_bindings.surface_ref),
          tab_id=COALESCE(NULLIF(excluded.tab_id, ''), session_bindings.tab_id),
          pane_id=COALESCE(NULLIF(excluded.pane_id, ''), session_bindings.pane_id),
          process_title=COALESCE(NULLIF(excluded.process_title, ''), session_bindings.process_title),
          tty=COALESCE(NULLIF(excluded.tty, ''), session_bindings.tty),
          payload_json=COALESCE(NULLIF(excluded.payload_json, ''), session_bindings.payload_json)
        """,
        (
            row["tool"],
            row["session_id"],
            row["observed_at"],
            row["observed_at"],
            row["event"],
            row["source"],
            row.get("cwd"),
            row.get("transcript_path"),
            row.get("model"),
            row.get("permission_mode"),
            row.get("workspace_title"),
            row.get("normalized_title"),
            row.get("workspace_id"),
            row.get("workspace_ref"),
            row.get("workspace_index"),
            row.get("surface_id"),
            row.get("surface_ref"),
            row.get("tab_id"),
            row.get("pane_id"),
            row.get("process_title"),
            row.get("tty"),
            row.get("payload_json"),
        ),
    )


def export_latest(con: sqlite3.Connection) -> None:
    latest = {
        "updated_at": utc_now(),
        "database": str(db_path()),
        "recent_sessions": [
            dict(row)
            for row in con.execute(
                """
                SELECT tool, session_id, last_seen, workspace_title, cwd, transcript_path
                FROM session_bindings
                ORDER BY last_seen DESC
                LIMIT 50
                """
            )
        ],
    }
    DEFAULT_LATEST_JSON.parent.mkdir(parents=True, exist_ok=True)
    DEFAULT_LATEST_JSON.write_text(json.dumps(latest, indent=2, ensure_ascii=False), encoding="utf-8")


def cmd_record(args: argparse.Namespace) -> int:
    raw = sys.stdin.read()
    try:
        payload = json.loads(raw) if raw.strip() else {}
    except json.JSONDecodeError:
        payload = {"raw": raw}
    with connect_db() as con:
        rows = tree_workspaces()
        workspace = current_workspace()
        insert_workspace_observations(con, f"{args.tool}-record", rows)
        record_memory_snapshot(con, f"{args.tool}-record", rows)
        row = event_from_payload(payload, args, workspace)
        upsert_event(con, row)
        export_latest(con)
    return 0


def cmd_record_resume(args: argparse.Namespace) -> int:
    payload = {
        "session_id": args.session_id,
        "cwd": args.cwd,
        "hook_event_name": args.event,
    }
    args.source = args.source or f"{args.tool}-zsh-wrapper"
    with connect_db() as con:
        rows = tree_workspaces()
        workspace = current_workspace()
        insert_workspace_observations(con, f"{args.tool}-resume", rows)
        record_memory_snapshot(con, f"{args.tool}-resume", rows)
        row = event_from_payload(payload, args, workspace)
        upsert_event(con, row)
        export_latest(con)
    return 0


def cmd_pin(args: argparse.Namespace) -> int:
    title = clean(args.title)
    if not title:
        current = current_workspace()
        title = clean(current.get("workspace_title"))
    if not title:
        print("pin: missing title. Pass --title or run from a CMUX workspace with a title.")
        return 2
    session_id = clean(args.session_id)
    if not session_id:
        print("pin: missing --session-id")
        return 2
    with connect_db() as con:
        row = con.execute(
            """
            SELECT * FROM session_bindings
            WHERE tool = ? AND session_id = ?
            """,
            (args.tool, session_id),
        ).fetchone()
        cwd = clean(args.cwd) or (row["cwd"] if row else None) or str(DEFAULT_RESTORE_CWD)
        now = utc_now()
        con.execute(
            """
            INSERT INTO recovery_pins (
              normalized_title, workspace_title, tool, session_id, cwd, note, created_at, updated_at
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ON CONFLICT(normalized_title) DO UPDATE SET
              workspace_title=excluded.workspace_title,
              tool=excluded.tool,
              session_id=excluded.session_id,
              cwd=excluded.cwd,
              note=excluded.note,
              updated_at=excluded.updated_at
            """,
            (normalize_title(title), title, args.tool, session_id, cwd, clean(args.note), now, now),
        )
        export_latest(con)
    print(f"pin: {title!r} -> {args.tool} {session_id} cwd={cwd}")
    return 0


def cmd_ignore(args: argparse.Namespace) -> int:
    session_id = clean(args.session_id)
    if not session_id:
        print("ignore: missing --session-id")
        return 2
    with connect_db() as con:
        con.execute(
            """
            INSERT INTO ignored_sessions (tool, session_id, reason, ignored_at)
            VALUES (?, ?, ?, ?)
            ON CONFLICT(tool, session_id) DO UPDATE SET
              reason=excluded.reason,
              ignored_at=excluded.ignored_at
            """,
            (args.tool, session_id, clean(args.reason), utc_now()),
        )
        export_latest(con)
    print(f"ignore: {args.tool} {session_id}")
    return 0


def cmd_snapshot(args: argparse.Namespace) -> int:
    with connect_db() as con:
        rows = tree_workspaces()
        insert_workspace_observations(con, args.source, rows)
        record_memory_snapshot(con, args.source, rows)
        export_latest(con)
    if not args.quiet:
        print(f"snapshot: {len(rows)} workspaces")
    return 0


def format_mb(kb: int | float | None) -> str:
    return f"{(float(kb or 0) / 1024):.1f} MB"


def mb_to_kb(value: float) -> int:
    return int(value * 1024)


def gb_to_kb(value: float) -> int:
    return int(value * 1024 * 1024)


def format_age(seconds: float) -> str:
    seconds = max(0, int(seconds))
    if seconds < 60:
        return f"{seconds}s"
    minutes = seconds // 60
    if minutes < 60:
        return f"{minutes}m"
    hours = minutes // 60
    if hours < 48:
        return f"{hours}h"
    days = hours // 24
    return f"{days}d"


def parse_duration(value: str) -> float:
    text = value.strip().lower()
    match = re.fullmatch(r"(\d+(?:\.\d+)?)([smhd]?)", text)
    if not match:
        raise argparse.ArgumentTypeError("duration must look like 30m, 6h, or 7d")
    amount = float(match.group(1))
    unit = match.group(2) or "s"
    scale = {"s": 1, "m": 60, "h": 60 * 60, "d": 24 * 60 * 60}[unit]
    return amount * scale


def cmd_memory_snapshot(args: argparse.Namespace) -> int:
    with connect_db() as con:
        rows = tree_workspaces()
        insert_workspace_observations(con, args.source, rows)
        samples = record_memory_snapshot(con, args.source, rows, force=True)
        export_latest(con)
    if not args.quiet:
        print(f"memory-snapshot: {len(samples)} workspaces")
        for item in sorted(samples, key=lambda row: int(row.get("total_rss_kb") or 0), reverse=True)[: args.limit]:
            print(
                f"{item.get('workspace_index', '')}\t{format_mb(item.get('total_rss_kb'))}\t"
                f"cpu={float(item.get('total_pcpu') or 0.0):.1f}%\t"
                f"{item.get('process_count', 0)} procs\t{item.get('workspace_title') or ''}"
            )
    return 0


def cmd_memory_top(args: argparse.Namespace) -> int:
    since_seconds = parse_duration(args.since)
    since = (
        dt.datetime.now(dt.timezone.utc) - dt.timedelta(seconds=since_seconds)
    ).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    groups: dict[tuple[str, str, str], dict[str, Any]] = {}
    with connect_db() as con:
        rows = con.execute(
            """
            SELECT *
            FROM memory_workspace_samples
            WHERE observed_at >= ?
            ORDER BY observed_at ASC
            """,
            (since,),
        ).fetchall()
    for row in rows:
        key = (
            row["normalized_title"] or "",
            row["workspace_id"] or "",
            row["surface_id"] or "",
        )
        item = groups.setdefault(
            key,
            {
                "workspace_index": row["workspace_index"],
                "workspace_title": row["workspace_title"],
                "latest_at": row["observed_at"],
                "latest_rss_kb": row["total_rss_kb"],
                "latest_pcpu": row["total_pcpu"],
                "max_rss_kb": row["total_rss_kb"],
                "max_pcpu": row["total_pcpu"],
                "samples": 0,
                "top_processes_json": row["top_processes_json"],
            },
        )
        item["samples"] += 1
        if parse_time(row["observed_at"]) >= parse_time(item["latest_at"]):
            item["workspace_index"] = row["workspace_index"]
            item["workspace_title"] = row["workspace_title"]
            item["latest_at"] = row["observed_at"]
            item["latest_rss_kb"] = row["total_rss_kb"]
            item["latest_pcpu"] = row["total_pcpu"]
            item["top_processes_json"] = row["top_processes_json"]
        item["max_rss_kb"] = max(int(item["max_rss_kb"] or 0), int(row["total_rss_kb"] or 0))
        item["max_pcpu"] = max(float(item["max_pcpu"] or 0.0), float(row["total_pcpu"] or 0.0))
    ranked = sorted(groups.values(), key=lambda item: int(item.get("max_rss_kb") or 0), reverse=True)
    for item in ranked[: args.limit]:
        top_names = ""
        try:
            top = json.loads(item.get("top_processes_json") or "[]")
            top_names = ", ".join(
                f"{row.get('name')} {format_mb(row.get('rss_kb'))}/{float(row.get('pcpu') or 0.0):.1f}%"
                for row in top[:3]
                if row.get("name")
            )
        except json.JSONDecodeError:
            top_names = ""
        print(
            f"{item.get('workspace_index', '')}\tlatest={format_mb(item.get('latest_rss_kb'))}\t"
            f"max={format_mb(item.get('max_rss_kb'))}\tcpu={float(item.get('latest_pcpu') or 0.0):.1f}%\t"
            f"max_cpu={float(item.get('max_pcpu') or 0.0):.1f}%\tsamples={item.get('samples')}\t"
            f"{item.get('workspace_title') or ''}\t{top_names}"
        )
    return 0


def cmd_memory_list(args: argparse.Namespace) -> int:
    with connect_db() as con:
        latest = con.execute("SELECT max(observed_at) AS observed_at FROM memory_workspace_samples").fetchone()
        observed_at = latest["observed_at"] if latest else None
        if not observed_at:
            return 0
        rows = con.execute(
            """
            SELECT workspace_index, workspace_title, process_count, total_rss_kb, total_pmem, total_pcpu
            FROM memory_workspace_samples
            WHERE observed_at = ?
            ORDER BY workspace_index
            """,
            (observed_at,),
        ).fetchall()
    if not args.quiet:
        print(f"latest sample: {observed_at}")
    for row in rows[: args.limit if args.limit is not None else None]:
        print(
            f"{row['workspace_index']}\t{format_mb(row['total_rss_kb'])}\t"
            f"mem={float(row['total_pmem'] or 0.0):.1f}%\tcpu={float(row['total_pcpu'] or 0.0):.1f}%\t"
            f"{row['process_count']} procs\t{row['workspace_title'] or ''}"
        )
    return 0


SIDEBAR_METRIC_PREFIX = "cmux: "


def strip_managed_sidebar_metric(description: str | None) -> str:
    lines = (description or "").splitlines()
    return "\n".join(line for line in lines if not line.startswith(SIDEBAR_METRIC_PREFIX)).strip()


def sidebar_metric_line(sample: dict[str, Any]) -> str:
    rss_mb = float(sample.get("total_rss_kb") or 0) / 1024.0
    cpu = float(sample.get("total_pcpu") or 0.0)
    procs = int(sample.get("process_count") or 0)
    if rss_mb >= 1024:
        rss = f"{rss_mb / 1024.0:.1f}GB"
    else:
        rss = f"{rss_mb:.0f}MB"
    return f"{SIDEBAR_METRIC_PREFIX}rss={rss} cpu={cpu:.1f}% procs={procs}"


def build_sidebar_description(sample: dict[str, Any], clear: bool = False) -> str:
    original = strip_managed_sidebar_metric(sample.get("workspace_description"))
    if clear:
        return original
    metric = sidebar_metric_line(sample)
    return f"{metric}\n{original}" if original else metric


def set_workspace_description(workspace: str, description: str) -> bool:
    if description.strip():
        return run_cmux(
            [
                "workspace-action",
                "--workspace",
                workspace,
                "--action",
                "set-description",
                "--description",
                description,
            ],
            timeout=5.0,
        ) is not None
    return run_cmux(
        ["workspace-action", "--workspace", workspace, "--action", "clear-description"],
        timeout=5.0,
    ) is not None


def cmd_sidebar_metrics(args: argparse.Namespace) -> int:
    with connect_db() as con:
        rows = tree_workspaces()
        insert_workspace_observations(con, args.source, rows)
        samples = record_memory_snapshot(con, args.source, rows, force=True)
        export_latest(con)
        con.commit()

    samples.sort(key=lambda item: (item.get("workspace_index") is None, item.get("workspace_index") or 0))
    changed = 0
    failed = 0
    for item in samples:
        workspace = item.get("workspace_ref") or item.get("workspace_id")
        if not workspace:
            failed += 1
            continue
        next_description = build_sidebar_description(item, clear=args.clear)
        current_description = item.get("workspace_description") or ""
        will_change = next_description != current_description
        if will_change:
            changed += 1
        if args.execute and will_change and not set_workspace_description(str(workspace), next_description):
            failed += 1

    action = "cleared" if args.clear else "updated"
    mode = "executed" if args.execute else "dry-run"
    print(f"sidebar-metrics: {mode} {action}={changed} failed={failed} workspaces={len(samples)}")
    for item in samples[: args.limit]:
        title = item.get("workspace_title") or ""
        print(f"{item.get('workspace_index', '')}\t{sidebar_metric_line(item)}\t{title}")
    if not args.execute:
        print("sidebar-metrics: dry run only. Add --execute to write CMUX workspace descriptions.")
    return 0 if failed == 0 else 1


def latest_memory_samples(con: sqlite3.Connection) -> list[dict[str, Any]]:
    latest = con.execute("SELECT max(observed_at) AS observed_at FROM memory_workspace_samples").fetchone()
    observed_at = latest["observed_at"] if latest else None
    if not observed_at:
        return []
    rows = con.execute(
        """
        SELECT *
        FROM memory_workspace_samples
        WHERE observed_at = ?
        ORDER BY workspace_index
        """,
        (observed_at,),
    ).fetchall()
    out: list[dict[str, Any]] = []
    for row in rows:
        item = dict(row)
        item.setdefault("selected", 0)
        item.setdefault("active", 0)
        item.setdefault("pinned", 0)
        out.append(item)
    return out


def score_candidate(current: dict[str, Any], candidate: sqlite3.Row) -> int:
    score = 0
    current_title = current.get("normalized_title")
    candidate_title = candidate["normalized_title"]
    candidate_workspace_title = normalize_title(candidate["workspace_title"])
    title_match = title_matches(current_title, candidate_title, candidate_workspace_title)
    fallback_match = generic_workspace_fallback_match(current, candidate)
    topic_fallback_match = untitled_topic_fallback_match(current, candidate)
    surface_match = bool(current.get("surface_id") and current.get("surface_id") == candidate["surface_id"])
    workspace_id_match = bool(current.get("workspace_id") and current.get("workspace_id") == candidate["workspace_id"])
    raw_workspace_ref_match = bool(current.get("workspace_ref") and current.get("workspace_ref") == candidate["workspace_ref"])
    raw_index_match = bool(
        current.get("workspace_index") is not None
        and candidate["workspace_index"] is not None
        and current.get("workspace_index") == candidate["workspace_index"]
        and candidate_title
    )
    ordinal_match_allowed = not current_title or title_match
    workspace_ref_match = raw_workspace_ref_match and ordinal_match_allowed
    index_match = raw_index_match and ordinal_match_allowed
    cwd_match = same_path(current.get("current_directory"), candidate["cwd"])
    resume_cwd = candidate_cwd(dict(candidate))
    resume_cwd_match = same_path(current.get("current_directory"), str(resume_cwd))

    # The tab title is the source of truth. For generic restored tabs like
    # "Development", or specific tabs whose Codex hook never attached the title,
    # Codex state may be the only recent record available after a crash.
    if not title_match and not fallback_match and not topic_fallback_match:
        return 0

    if surface_match:
        score += 120
    if workspace_id_match:
        score += 90
    if workspace_ref_match:
        score += 35
    if title_match:
        score += 110
    if fallback_match:
        score += 120
    if topic_fallback_match:
        score += 105
    if cwd_match:
        score += 25
    if resume_cwd_match and not cwd_match:
        score += 35
    if index_match:
        score += 8
    age = max(0.0, time.time() - parse_time(candidate["last_seen"]))
    if age < 6 * 60 * 60:
        score += 25
    elif age < 24 * 60 * 60:
        score += 18
    elif age < 7 * 24 * 60 * 60:
        score += 10
    elif age < 30 * 24 * 60 * 60:
        score += 4
    return score


def load_candidates(con: sqlite3.Connection, current: dict[str, Any]) -> list[dict[str, Any]]:
    pin = None
    if current.get("normalized_title"):
        pin = con.execute(
            """
            SELECT * FROM recovery_pins
            WHERE normalized_title = ?
            """,
            (current.get("normalized_title"),),
        ).fetchone()
    rows = candidate_rows(con, current)
    candidates: list[dict[str, Any]] = []
    screen_refs = [
        item
        for item in current.get("screen_resume_refs") or []
        if isinstance(item, dict) and item.get("tool") in {"claude", "codex"} and item.get("session_id")
    ]
    screen_ref_keys = {(item["tool"], item["session_id"]) for item in screen_refs}
    screen_snippets = screen_match_snippets(str(current.get("screen_text") or ""))
    for row in rows:
        score = score_candidate(current, row)
        pinned = bool(pin and pin["tool"] == row["tool"] and pin["session_id"] == row["session_id"])
        item = dict(row)
        if pinned:
            item["cwd"] = pin["cwd"] or item.get("cwd")
            item["workspace_title"] = pin["workspace_title"] or item.get("workspace_title")
            item["normalized_title"] = pin["normalized_title"] or item.get("normalized_title")
        item["pinned"] = pinned
        item["title_match"] = title_matches(current.get("normalized_title"), item.get("normalized_title"), item.get("workspace_title"))
        item["generic_workspace_fallback_match"] = generic_workspace_fallback_match(current, item)
        item["untitled_topic_fallback_match"] = untitled_topic_fallback_match(current, item)
        item["surface_match"] = bool(current.get("surface_id") and current.get("surface_id") == item.get("surface_id"))
        item["workspace_id_match"] = bool(current.get("workspace_id") and current.get("workspace_id") == item.get("workspace_id"))
        item["workspace_ref_match"] = bool(
            current.get("workspace_ref")
            and current.get("workspace_ref") == item.get("workspace_ref")
            and (not current.get("normalized_title") or item["title_match"])
        )
        item["index_match"] = bool(
            current.get("workspace_index") is not None
            and item.get("workspace_index") is not None
            and current.get("workspace_index") == item.get("workspace_index")
            and (not current.get("normalized_title") or item["title_match"])
        )
        item["cwd_match"] = same_path(current.get("current_directory"), item.get("cwd"))
        item["resume_cwd"] = str(candidate_cwd(item))
        item["resume_cwd_match"] = same_path(current.get("current_directory"), item.get("resume_cwd"))
        item["process_title_topic_match"] = False
        item.update(transcript_info(item.get("transcript_path")))
        topic = topic_match_info(current, item)
        item.update(topic)
        if score <= 0:
            if pinned:
                score = 1
            else:
                continue
        score += int(topic.get("topic_relevance") or 0)
        score -= int(topic.get("topic_penalty") or 0)
        if generic_workflow_topic_mismatch(item):
            continue
        if score <= 0 and not pinned:
            continue
        if pinned:
            score += 50000
        if int(topic.get("topic_relevance") or 0) >= 36:
            age = max(0.0, time.time() - parse_time(item.get("last_seen")))
            if age < 24 * 60 * 60:
                score += 15
        item["score"] = score
        item["command"] = resume_command(item)
        candidates.append(item)
    for idx, ref in enumerate(screen_refs):
        if any(item["tool"] == ref["tool"] and item["session_id"] == ref["session_id"] for item in candidates):
            for item in candidates:
                if item["tool"] == ref["tool"] and item["session_id"] == ref["session_id"]:
                    if screen_resume_title_allowed(current, item):
                        item["current_screen_resume"] = True
                        item["score"] = max(int(item.get("score") or 0), 20000 - idx)
            continue
        row = session_binding_row(con, ref["tool"], ref["session_id"])
        base = dict(row) if row else {}
        if current.get("normalized_title") and not base:
            continue
        if base and not screen_resume_title_allowed(current, base):
            continue
        item = {
            "tool": ref["tool"],
            "session_id": ref["session_id"],
            "first_seen": base.get("first_seen") or utc_now(),
            "last_seen": base.get("last_seen") or utc_now(),
            "last_event": base.get("last_event") or "screen-resume",
            "last_source": base.get("last_source") or "current-screen",
            "cwd": base.get("cwd") or current.get("current_directory") or str(DEFAULT_RESTORE_CWD),
            "transcript_path": base.get("transcript_path"),
            "model": base.get("model"),
            "permission_mode": base.get("permission_mode"),
            "workspace_title": base.get("workspace_title") or current.get("workspace_title"),
            "normalized_title": base.get("normalized_title") or current.get("normalized_title"),
            "workspace_id": current.get("workspace_id"),
            "workspace_ref": current.get("workspace_ref"),
            "workspace_index": current.get("workspace_index"),
            "surface_id": current.get("surface_id"),
            "surface_ref": current.get("surface_ref"),
            "tab_id": current.get("tab_id"),
            "pane_id": current.get("pane_id"),
            "process_title": base.get("process_title"),
            "tty": current.get("tty"),
            "payload_json": base.get("payload_json"),
            "score": 20000 - idx,
            "pinned": False,
            "current_screen_resume": True,
            "title_match": title_matches(current.get("normalized_title"), base.get("normalized_title"), base.get("workspace_title")),
            "generic_workspace_fallback_match": generic_workspace_fallback_match(current, base) if base else False,
            "untitled_topic_fallback_match": untitled_topic_fallback_match(current, base) if base else False,
            "surface_match": True,
            "workspace_id_match": True,
            "workspace_ref_match": True,
            "index_match": False,
            "cwd_match": same_path(current.get("current_directory"), base.get("cwd")),
        }
        item["resume_cwd"] = str(candidate_cwd(item))
        item["resume_cwd_match"] = same_path(current.get("current_directory"), item.get("resume_cwd"))
        item["process_title_topic_match"] = False
        item.update(transcript_info(item.get("transcript_path")))
        item.update(topic_match_info(current, item))
        item["command"] = resume_command(item)
        candidates.append(item)
    for item in candidates:
        if (item["tool"], item["session_id"]) in screen_ref_keys and screen_resume_title_allowed(current, item):
            item["current_screen_resume"] = True
    if screen_snippets and not screen_refs:
        for row in session_binding_rows(
            con,
            "sb.transcript_path IS NOT NULL AND sb.transcript_path != ''",
            (),
            limit=SCREEN_TRANSCRIPT_SCAN_LIMIT,
        ):
            match = screen_transcript_match_info(screen_snippets, row["transcript_path"])
            if int(match.get("screen_match_score") or 0) <= 0:
                continue
            existing = next(
                (item for item in candidates if item["tool"] == row["tool"] and item["session_id"] == row["session_id"]),
                None,
            )
            if existing:
                existing["current_screen_transcript_match"] = True
                existing.update(match)
                existing["score"] = max(int(existing.get("score") or 0), 19000 + int(match["screen_match_score"]))
                continue
            item = dict(row)
            item["pinned"] = False
            item["title_match"] = title_matches(current.get("normalized_title"), item.get("normalized_title"), item.get("workspace_title"))
            item["generic_workspace_fallback_match"] = generic_workspace_fallback_match(current, item)
            item["untitled_topic_fallback_match"] = untitled_topic_fallback_match(current, item)
            item["surface_match"] = bool(current.get("surface_id") and current.get("surface_id") == item.get("surface_id"))
            item["workspace_id_match"] = bool(current.get("workspace_id") and current.get("workspace_id") == item.get("workspace_id"))
            item["workspace_ref_match"] = bool(current.get("workspace_ref") and current.get("workspace_ref") == item.get("workspace_ref"))
            item["index_match"] = bool(
                current.get("workspace_index") is not None
                and item.get("workspace_index") is not None
                and current.get("workspace_index") == item.get("workspace_index")
            )
            item["cwd_match"] = same_path(current.get("current_directory"), item.get("cwd"))
            item["resume_cwd"] = str(candidate_cwd(item))
            item["resume_cwd_match"] = same_path(current.get("current_directory"), item.get("resume_cwd"))
            item["process_title_topic_match"] = False
            item["current_screen_transcript_match"] = True
            item.update(transcript_info(item.get("transcript_path")))
            item.update(topic_match_info(current, item))
            item.update(match)
            item["score"] = 19000 + int(match["screen_match_score"])
            item["command"] = resume_command(item)
            candidates.append(item)
    if pin and not any(item["tool"] == pin["tool"] and item["session_id"] == pin["session_id"] for item in candidates):
        item = {
            "tool": pin["tool"],
            "session_id": pin["session_id"],
            "first_seen": pin["created_at"],
            "last_seen": pin["updated_at"],
            "last_event": "pin",
            "last_source": "recovery-pin",
            "cwd": pin["cwd"],
            "transcript_path": None,
            "model": None,
            "permission_mode": None,
            "workspace_title": pin["workspace_title"],
            "normalized_title": pin["normalized_title"],
            "workspace_id": None,
            "workspace_ref": None,
            "workspace_index": None,
            "surface_id": None,
            "surface_ref": None,
            "tab_id": None,
            "pane_id": None,
            "process_title": None,
            "tty": None,
            "payload_json": None,
            "score": 50000,
            "pinned": True,
            "title_match": True,
            "generic_workspace_fallback_match": False,
            "untitled_topic_fallback_match": False,
            "surface_match": False,
            "workspace_id_match": False,
            "workspace_ref_match": False,
            "index_match": False,
            "cwd_match": same_path(current.get("current_directory"), pin["cwd"]),
        }
        item["resume_cwd"] = str(candidate_cwd(item))
        item["resume_cwd_match"] = same_path(current.get("current_directory"), item.get("resume_cwd"))
        item.update(transcript_info(item.get("transcript_path")))
        item["command"] = resume_command(item)
        candidates.append(item)
    candidates.sort(key=lambda item: (item["score"], parse_time(item.get("last_seen"))), reverse=True)
    return candidates


def session_binding_rows(
    con: sqlite3.Connection,
    where_sql: str = "",
    params: tuple[Any, ...] = (),
    *,
    limit: int = 500,
) -> list[sqlite3.Row]:
    where = f" AND ({where_sql})" if where_sql else ""
    return con.execute(
        """
        SELECT sb.* FROM session_bindings sb
        LEFT JOIN ignored_sessions ig
          ON ig.tool = sb.tool AND ig.session_id = sb.session_id
        WHERE sb.session_id IS NOT NULL AND sb.session_id != ''
          AND ig.session_id IS NULL
        """ + where + """
        ORDER BY last_seen DESC
        LIMIT ?
        """,
        (*params, limit),
    ).fetchall()


def session_binding_row(con: sqlite3.Connection, tool: str, session_id: str) -> sqlite3.Row | None:
    return con.execute(
        """
        SELECT sb.* FROM session_bindings sb
        LEFT JOIN ignored_sessions ig
          ON ig.tool = sb.tool AND ig.session_id = sb.session_id
        WHERE sb.tool = ? AND sb.session_id = ?
          AND ig.session_id IS NULL
        """,
        (tool, session_id),
    ).fetchone()


def candidate_rows(con: sqlite3.Connection, current: dict[str, Any]) -> list[sqlite3.Row]:
    rows: list[sqlite3.Row] = []
    seen: set[tuple[str, str]] = set()

    def add(batch: list[sqlite3.Row]) -> None:
        for row in batch:
            key = (row["tool"], row["session_id"])
            if key in seen:
                continue
            seen.add(key)
            rows.append(row)

    add(session_binding_rows(con, limit=500))

    clauses: list[str] = []
    params: list[Any] = []
    if current.get("normalized_title"):
        clauses.append("sb.normalized_title = ?")
        params.append(current.get("normalized_title"))
    for column, key in [
        ("workspace_id", "workspace_id"),
        ("workspace_ref", "workspace_ref"),
        ("surface_id", "surface_id"),
        ("surface_ref", "surface_ref"),
    ]:
        if current.get(key):
            clauses.append(f"sb.{column} = ?")
            params.append(current.get(key))
    if current.get("workspace_index") is not None and current.get("normalized_title"):
        clauses.append("(sb.workspace_index = ? AND sb.normalized_title = ?)")
        params.extend([current.get("workspace_index"), current.get("normalized_title")])
    cwd_values = [str(path) for path in path_variants(current.get("current_directory"))]
    if cwd_values:
        placeholders = ",".join("?" for _ in cwd_values)
        clauses.append(f"sb.cwd IN ({placeholders})")
        params.extend(cwd_values)
    if clauses:
        add(session_binding_rows(con, " OR ".join(clauses), tuple(params), limit=1000))
    return rows


def payload_value_text(value: Any) -> str:
    if isinstance(value, str):
        return value
    if isinstance(value, dict):
        parts: list[str] = []
        for key in ["prompt", "message", "content", "text", "last_assistant_message", "summary", "command"]:
            if key in value:
                parts.append(payload_value_text(value.get(key)))
        return " ".join(part for part in parts if part)
    if isinstance(value, list):
        return " ".join(payload_value_text(item) for item in value)
    return ""


def candidate_topic_text(candidate: dict[str, Any]) -> str:
    parts = [
        candidate.get("process_title") or "",
        candidate.get("first_user_prompt") or "",
    ]
    raw_payload = candidate.get("payload_json")
    if raw_payload:
        try:
            payload = json.loads(str(raw_payload))
        except json.JSONDecodeError:
            payload = {}
        parts.append(payload_value_text(payload))
    return " ".join(part for part in parts if part)


def topic_match_info(current: dict[str, Any], candidate: dict[str, Any]) -> dict[str, Any]:
    if not candidate.get("title_match") and not candidate.get("untitled_topic_fallback_match"):
        return {"topic_relevance": 0, "topic_penalty": 0, "topic_terms": [], "topic_hits": []}
    title = current.get("normalized_title") or current.get("workspace_title")
    terms = title_topic_signals(title)
    if not terms:
        return {"topic_relevance": 0, "topic_penalty": 0, "topic_terms": [], "topic_hits": []}
    text = candidate_topic_text(candidate)
    hits = topic_hits_for_title(title, text)
    relevance = min(72, len(hits) * 18)
    marker_text = text.lower()
    generic_workflow = any(marker in marker_text for marker in GENERIC_WORKFLOW_MARKERS)
    raw_title_terms = set(normalize_title(current.get("workspace_title") or current.get("normalized_title")).split())
    bug_or_investigation_title = bool(raw_title_terms & BUG_OR_INVESTIGATION_TERMS)
    title_is_generic_outreach = (
        bool(terms)
        and not bug_or_investigation_title
        and all(term in GENERIC_OUTREACH_TITLE_TERMS for term in terms)
    )
    penalty = 450 if generic_workflow and not title_is_generic_outreach else 0
    return {
        "topic_relevance": relevance,
        "topic_penalty": penalty,
        "topic_terms": terms,
        "topic_hits": hits,
    }


def usable_cwd(value: str | None) -> Path:
    candidates: list[Path] = path_variants(value)
    candidates.append(DEFAULT_RESTORE_CWD)
    for candidate in candidates:
        if candidate.exists() and candidate.is_dir():
            return candidate
    return DEFAULT_RESTORE_CWD


def claude_project_cwd(candidate: dict[str, Any]) -> Path | None:
    transcript_path = candidate.get("transcript_path")
    if not transcript_path:
        return None
    path = Path(str(transcript_path)).expanduser()
    if len(path.parts) < 4 or path.parent.parent.name != "projects" or path.parent.parent.parent.name != ".claude":
        return None
    slug = path.parent.name
    search: list[Path] = []
    for raw in [candidate.get("cwd"), DEFAULT_RESTORE_CWD]:
        for variant in path_variants(raw):
            search.append(variant)
            search.extend(variant.parents)
    seen: set[str] = set()
    for item in search:
        key = str(item)
        if key in seen:
            continue
        seen.add(key)
        if item.exists() and item.is_dir() and claude_project_slug(item) == slug:
            return item
    return None


def candidate_cwd(candidate: dict[str, Any]) -> Path:
    if candidate.get("tool") == "claude":
        project_cwd = claude_project_cwd(candidate)
        if project_cwd:
            return project_cwd
    return usable_cwd(candidate.get("cwd"))


def transcript_info(value: str | None) -> dict[str, Any]:
    info: dict[str, Any] = {"transcript_exists": False, "transcript_bytes": None, "first_user_prompt": None}
    if not value:
        return info
    path = Path(value).expanduser()
    try:
        stat = path.stat()
    except OSError:
        return info
    info["transcript_exists"] = True
    info["transcript_bytes"] = stat.st_size
    try:
        with path.open("r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                content = user_text_from_transcript_object(obj)
                text = re.sub(r"\s+", " ", str(content or "")).strip()
                if text and not transcript_prompt_noise(text):
                    info["first_user_prompt"] = text[:220]
                    break
    except OSError:
        pass
    return info


def transcript_prompt_noise(text: str) -> bool:
    normalized = text.strip().lower()
    return (
        normalized.startswith("# agents.md instructions")
        or normalized.startswith("knowledge cutoff:")
        or normalized.startswith("<environment_context>")
        or "<instructions>" in normalized[:500]
        or "# project-doc" in normalized[:500]
    )


def text_from_content(value: Any) -> str:
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        parts: list[str] = []
        for item in value:
            if isinstance(item, dict):
                parts.append(str(item.get("text") or item.get("content") or ""))
            else:
                parts.append(str(item))
        return " ".join(part for part in parts if part)
    return str(value or "")


def user_text_from_transcript_object(obj: dict[str, Any]) -> str:
    if obj.get("type") == "user":
        message = obj.get("message")
        if isinstance(message, dict):
            return text_from_content(message.get("content"))
        return text_from_content(obj.get("content"))
    payload = obj.get("payload")
    if isinstance(payload, dict):
        if payload.get("role") == "user":
            return text_from_content(payload.get("content"))
        if payload.get("type") == "message" and payload.get("role") == "user":
            return text_from_content(payload.get("content"))
        if payload.get("type") == "user_message" or payload.get("prompt"):
            return text_from_content(payload.get("prompt") or payload.get("message"))
    return ""


def transcript_text_from_object(obj: dict[str, Any]) -> str:
    payload = obj.get("payload")
    if isinstance(payload, dict):
        for key in ("message", "text", "output", "arguments"):
            if payload.get(key):
                return text_from_content(payload.get(key))
        if payload.get("type") == "message":
            return text_from_content(payload.get("content"))
    return user_text_from_transcript_object(obj)


def recent_transcript_text(value: str | None, *, max_bytes: int = 2_000_000) -> str:
    if not value:
        return ""
    path = Path(value).expanduser()
    try:
        size = path.stat().st_size
        with path.open("rb") as handle:
            if size > max_bytes:
                handle.seek(size - max_bytes)
                handle.readline()
            raw = handle.read(max_bytes)
    except OSError:
        return ""
    text_parts: list[str] = []
    for raw_line in raw.decode("utf-8", errors="replace").splitlines():
        try:
            obj = json.loads(raw_line)
        except json.JSONDecodeError:
            continue
        text = re.sub(r"\s+", " ", transcript_text_from_object(obj)).strip()
        if text:
            text_parts.append(text[:2000])
    return "\n".join(text_parts)[-120_000:]


def normalize_match_text(value: str) -> str:
    return re.sub(r"[^a-z0-9_.:/-]+", " ", value.lower()).strip()


def screen_match_snippets(screen_text: str) -> list[str]:
    ignored = (
        "cmr:",
        "first_user=",
        "last login:",
        "multiple possible sessions found",
        "robertgrzesik@",
        "pick one with",
        "press ctrl",
        "debug log",
        "resume_cwd=",
        "session=",
        "title=",
        "cwd=",
        "original token count",
        "wall time:",
        "process exited",
        "process running",
        "chunk id:",
    )
    snippets: list[str] = []
    seen: set[str] = set()
    for raw_line in screen_text.splitlines():
        line = raw_line.strip(" │└─•⏺■*`'\"")
        lower = line.lower()
        if len(line) < 42 or any(marker in lower for marker in ignored):
            continue
        if sum(ch.isalpha() for ch in line) < 20:
            continue
        normalized = normalize_match_text(line)
        words = normalized.split()
        if len(words) < 6:
            continue
        snippet = " ".join(words[:24])
        if len(snippet) < 42 or snippet in seen:
            continue
        seen.add(snippet)
        snippets.append(snippet)
    snippets.sort(key=len, reverse=True)
    return snippets[:40]


def screen_transcript_match_info(snippets: list[str], transcript_path: str | None) -> dict[str, Any]:
    if not snippets or not transcript_path:
        return {"screen_match_score": 0, "screen_match_hits": []}
    transcript = normalize_match_text(recent_transcript_text(transcript_path))
    if not transcript:
        return {"screen_match_score": 0, "screen_match_hits": []}
    hits: list[str] = []
    for snippet in snippets:
        if snippet in transcript:
            hits.append(snippet)
        if len(hits) >= 5:
            break
    if len(hits) < 2 and not any(len(hit) >= 90 for hit in hits):
        return {"screen_match_score": 0, "screen_match_hits": hits}
    score = min(900, sum(min(180, len(hit)) for hit in hits))
    return {"screen_match_score": score, "screen_match_hits": hits}


def resume_command(candidate: dict[str, Any]) -> str:
    cwd = str(candidate_cwd(candidate))
    sid = str(candidate["session_id"])
    if candidate["tool"] == "codex":
        return f"cd {shlex.quote(cwd)} && codex -C {shlex.quote(cwd)} resume {shlex.quote(sid)}"
    return f"cd {shlex.quote(cwd)} && claude --resume {shlex.quote(sid)}"


def print_candidates(candidates: list[dict[str, Any]], limit: int = 8) -> None:
    for idx, item in enumerate(candidates[:limit], start=1):
        title = item.get("workspace_title") or "(no title)"
        cwd = item.get("cwd") or ""
        resume_cwd = item.get("resume_cwd") or ""
        size = ""
        if item.get("transcript_bytes") is not None:
            size = f" transcript={int(item['transcript_bytes']) / 1024 / 1024:.1f}MB"
        prompt = item.get("first_user_prompt")
        pin = " pinned" if item.get("pinned") else ""
        screen = " screen" if item.get("current_screen_resume") or item.get("current_screen_transcript_match") else ""
        if item.get("generic_workspace_fallback_match"):
            fallback = " recent-cwd"
        elif item.get("untitled_topic_fallback_match"):
            fallback = " topic-cwd"
        else:
            fallback = ""
        topic = ""
        if item.get("topic_relevance") or item.get("topic_penalty"):
            topic = f" topic=+{int(item.get('topic_relevance') or 0)}/-{int(item.get('topic_penalty') or 0)}"
        print(
            f"{idx}. {item['tool']}{pin}{screen}{fallback} session={item.get('session_id')} score={item['score']} last={item.get('last_seen')} "
            f"title={title!r} cwd={cwd} resume_cwd={resume_cwd}{size}{topic}"
        )
        if prompt:
            print(f"   first_user={prompt!r}")


def debug_dir() -> Path:
    return Path(os.environ.get("CMUX_RECOVERY_DEBUG_DIR", str(DEFAULT_DEBUG_DIR))).expanduser()


def public_current_summary(current: dict[str, Any]) -> dict[str, Any]:
    keys = [
        "workspace_title",
        "normalized_title",
        "codex_state_imported",
        "workspace_id",
        "workspace_ref",
        "workspace_index",
        "surface_id",
        "surface_ref",
        "tty",
        "current_directory",
        "screen_resume_refs",
    ]
    return {key: current.get(key) for key in keys}


def public_candidate_summary(item: dict[str, Any]) -> dict[str, Any]:
    keys = [
        "tool",
        "session_id",
        "score",
        "last_seen",
        "last_event",
        "last_source",
        "workspace_title",
        "normalized_title",
        "workspace_id",
        "workspace_ref",
        "workspace_index",
        "surface_id",
        "surface_ref",
        "cwd",
        "resume_cwd",
        "title_match",
        "generic_workspace_fallback_match",
        "untitled_topic_fallback_match",
        "surface_match",
        "workspace_id_match",
        "workspace_ref_match",
        "index_match",
        "cwd_match",
        "resume_cwd_match",
        "process_title_topic_match",
        "current_screen_resume",
        "current_screen_transcript_match",
        "screen_match_score",
        "screen_match_hits",
        "pinned",
        "transcript_path",
        "transcript_exists",
        "transcript_bytes",
        "first_user_prompt",
        "command",
        "topic_relevance",
        "topic_penalty",
        "topic_terms",
        "topic_hits",
    ]
    return {key: item.get(key) for key in keys}


def write_recover_debug_log(
    *,
    action: str,
    status: str,
    current: dict[str, Any],
    selected: dict[str, Any] | None,
    candidates: list[dict[str, Any]],
    choice: int | None,
    dry_run: bool,
) -> Path:
    directory = debug_dir()
    directory.mkdir(parents=True, exist_ok=True)
    stamp = utc_now().replace(":", "").replace("-", "")
    title = normalize_title(current.get("workspace_title")) or "untitled"
    safe_title = re.sub(r"[^0-9a-z]+", "-", title).strip("-")[:48] or "untitled"
    path = directory / f"cmr-{stamp}-{safe_title}.json"
    payload = {
        "observed_at": utc_now(),
        "action": action,
        "status": status,
        "dry_run": dry_run,
        "choice": choice,
        "database": str(db_path()),
        "current": public_current_summary(current),
        "selected": public_candidate_summary(selected) if selected else None,
        "candidate_count": len(candidates),
        "candidates": [public_candidate_summary(item) for item in candidates[:25]],
    }
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")
    return path


def log_restore(
    con: sqlite3.Connection,
    action: str,
    status: str,
    current: dict[str, Any],
    selected: dict[str, Any] | None,
    candidates: list[dict[str, Any]],
    debug_path: Path | None = None,
) -> None:
    con.execute(
        """
        INSERT INTO restore_events (
          observed_at, action, status, workspace_title, normalized_title, workspace_id,
          surface_id, selected_tool, selected_session_id, score, command, details_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            utc_now(),
            action,
            status,
            current.get("workspace_title"),
            current.get("normalized_title"),
            current.get("workspace_id"),
            current.get("surface_id"),
            selected.get("tool") if selected else None,
            selected.get("session_id") if selected else None,
            selected.get("score") if selected else None,
            selected.get("command") if selected else None,
            json.dumps(
                {
                    "debug_log": str(debug_path) if debug_path else None,
                    "current": public_current_summary(current),
                    "candidates": [public_candidate_summary(item) for item in candidates[:10]],
                },
                default=str,
                ensure_ascii=False,
            ),
        ),
    )


def strong_candidate_match(item: dict[str, Any]) -> bool:
    if item.get("current_screen_resume"):
        return True
    if item.get("current_screen_transcript_match"):
        return True
    strong_keys = ("surface_match", "workspace_id_match", "workspace_ref_match", "cwd_match", "resume_cwd_match", "index_match")
    return any(item.get(key) for key in strong_keys)


def generic_workflow_topic_mismatch(item: dict[str, Any]) -> bool:
    if item.get("pinned"):
        return False
    if not item.get("title_match"):
        return False
    if int(item.get("topic_penalty") or 0) <= 0:
        return False
    if strong_candidate_match(item):
        return False
    return not substantial_topic_hits(item.get("topic_hits") or [])


def viable_candidate(item: dict[str, Any]) -> bool:
    return int(item.get("score") or 0) >= 75


def recent_cwd_fallback_can_auto_select(top: dict[str, Any], second: dict[str, Any] | None) -> bool:
    if not top.get("generic_workspace_fallback_match"):
        return False
    top_seen = parse_time(top.get("last_seen"))
    if top_seen <= 0:
        return False
    age = max(0.0, time.time() - top_seen)
    if age > GENERIC_FALLBACK_AUTO_SELECT_MAX_AGE_SECONDS:
        return False
    if second is None:
        return True
    if not second.get("generic_workspace_fallback_match") or not viable_candidate(second):
        return True
    second_seen = parse_time(second.get("last_seen"))
    return top_seen - second_seen >= GENERIC_FALLBACK_AUTO_SELECT_GAP_SECONDS


def choose_candidate(args: argparse.Namespace, candidates: list[dict[str, Any]]) -> tuple[str, dict[str, Any] | None]:
    if args.choice is not None:
        index = args.choice - 1
        if index < 0 or index >= len(candidates):
            return "invalid-choice", None
        return "selected", candidates[index]
    if not candidates:
        return "missing", None
    top = candidates[0]
    if not viable_candidate(top):
        if top.get("title_match"):
            return "ambiguous", None
        return "missing", None
    if top.get("current_screen_resume"):
        return "selected", top
    if top.get("current_screen_transcript_match"):
        return "selected", top
    second = candidates[1] if len(candidates) > 1 else None
    if top.get("generic_workspace_fallback_match"):
        if recent_cwd_fallback_can_auto_select(top, second):
            return "selected", top
        return "ambiguous", None
    top_strong = strong_candidate_match(top)
    second_title_match = bool(second and viable_candidate(second) and second.get("title_match"))
    if top.get("title_match") and not top_strong and second_title_match:
        return "ambiguous", None
    if top["score"] >= 75 and (second is None or top["score"] - second["score"] >= 20):
        return "selected", top
    return "ambiguous", None


def workspace_label(current: dict[str, Any]) -> str:
    return current.get("workspace_title") or current.get("normalized_title") or "unknown workspace"


def trim_candidate_rows(
    con: sqlite3.Connection,
    samples: list[dict[str, Any]],
    args: argparse.Namespace,
) -> tuple[int, int, list[dict[str, Any]], list[dict[str, Any]]]:
    total_rss_kb = sum(int(row.get("total_rss_kb") or 0) for row in samples)
    target_rss_kb = gb_to_kb(args.target_gb)
    min_rss_kb = mb_to_kb(args.min_mb)
    min_age_seconds = parse_duration(args.min_age)
    now = time.time()
    chooser_args = argparse.Namespace(choice=None)
    candidates: list[dict[str, Any]] = []
    skipped: list[dict[str, Any]] = []

    for sample in samples:
        rss_kb = int(sample.get("total_rss_kb") or 0)
        if rss_kb < min_rss_kb:
            continue
        if not args.include_active and (sample.get("selected") or sample.get("active")):
            skipped.append({"workspace": sample, "reason": "active"})
            continue
        if not (sample.get("workspace_ref") or sample.get("workspace_id")) or not (sample.get("surface_ref") or sample.get("surface_id")):
            skipped.append({"workspace": sample, "reason": "missing-cmux-target"})
            continue

        session_candidates = load_candidates(con, sample)
        status, selected = choose_candidate(chooser_args, session_candidates)
        if status != "selected" or selected is None:
            skipped.append({"workspace": sample, "reason": status, "candidates": session_candidates[:5]})
            continue

        age_seconds = max(0.0, now - parse_time(selected.get("last_seen")))
        if age_seconds < min_age_seconds:
            skipped.append({"workspace": sample, "reason": "recent", "selected": selected, "age_seconds": age_seconds})
            continue

        candidates.append(
            {
                "workspace": sample,
                "selected": selected,
                "rss_kb": rss_kb,
                "age_seconds": age_seconds,
            }
        )

    candidates.sort(key=lambda item: (int(item["rss_kb"]), float(item["age_seconds"])), reverse=True)
    return total_rss_kb, target_rss_kb, candidates, skipped


def plan_trim(args: argparse.Namespace, total_rss_kb: int, target_rss_kb: int, candidates: list[dict[str, Any]]) -> tuple[list[dict[str, Any]], int]:
    planned: list[dict[str, Any]] = []
    projected_rss_kb = total_rss_kb
    if not args.force and total_rss_kb <= target_rss_kb:
        return planned, projected_rss_kb
    for item in candidates:
        if len(planned) >= args.limit:
            break
        planned.append(item)
        projected_rss_kb = max(0, projected_rss_kb - int(item["rss_kb"]))
        if not args.force and projected_rss_kb <= target_rss_kb:
            break
    return planned, projected_rss_kb


def trim_item_summary(item: dict[str, Any], status: str | None = None) -> dict[str, Any]:
    workspace = item["workspace"]
    selected = item["selected"]
    out = {
        "status": status,
        "workspace_index": workspace.get("workspace_index"),
        "workspace_title": workspace.get("workspace_title"),
        "workspace_ref": workspace.get("workspace_ref"),
        "workspace_id": workspace.get("workspace_id"),
        "surface_ref": workspace.get("surface_ref"),
        "surface_id": workspace.get("surface_id"),
        "tool": selected.get("tool"),
        "session_id": selected.get("session_id"),
        "last_seen": selected.get("last_seen"),
        "rss_kb": item.get("rss_kb"),
        "age_seconds": item.get("age_seconds"),
    }
    return out


def log_trim(
    con: sqlite3.Connection,
    *,
    action: str,
    status: str,
    method: str,
    total_rss_kb: int,
    target_rss_kb: int,
    projected_rss_kb: int,
    candidates: list[dict[str, Any]],
    planned: list[dict[str, Any]],
    stopped_count: int,
    skipped: list[dict[str, Any]],
) -> None:
    con.execute(
        """
        INSERT INTO trim_events (
          observed_at, action, status, method, total_rss_kb, target_rss_kb,
          projected_rss_kb, candidate_count, stopped_count, details_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (
            utc_now(),
            action,
            status,
            method,
            total_rss_kb,
            target_rss_kb,
            projected_rss_kb,
            len(candidates),
            stopped_count,
            json.dumps(
                {
                    "planned": [trim_item_summary(item) for item in planned],
                    "skipped": [
                        {
                            "reason": item.get("reason"),
                            "workspace_index": (item.get("workspace") or {}).get("workspace_index"),
                            "workspace_title": (item.get("workspace") or {}).get("workspace_title"),
                        }
                        for item in skipped[:25]
                    ],
                },
                separators=(",", ":"),
                ensure_ascii=False,
            ),
        ),
    )


def stop_trim_item(item: dict[str, Any], method: str) -> bool:
    workspace = item["workspace"]
    workspace_target = workspace.get("workspace_ref") or workspace.get("workspace_id")
    surface_target = workspace.get("surface_ref") or workspace.get("surface_id")
    if not workspace_target or not surface_target:
        return False
    if method == "ctrl-c":
        return run_cmux(["send-key", "--workspace", str(workspace_target), "--surface", str(surface_target), "ctrl+c"], timeout=5.0) is not None
    return run_cmux(["respawn-pane", "--workspace", str(workspace_target), "--surface", str(surface_target)], timeout=5.0) is not None


def print_trim_report(
    *,
    args: argparse.Namespace,
    total_rss_kb: int,
    target_rss_kb: int,
    projected_rss_kb: int,
    candidates: list[dict[str, Any]],
    planned: list[dict[str, Any]],
    statuses: list[str],
) -> None:
    action = "stopped" if args.execute else "would stop"
    print(
        f"trim: total={format_mb(total_rss_kb)} target={format_mb(target_rss_kb)} "
        f"projected={format_mb(projected_rss_kb)} candidates={len(candidates)} planned={len(planned)}"
    )
    if not planned:
        if total_rss_kb <= target_rss_kb and not args.force:
            print("trim: current sampled total is under the target.")
        else:
            print("trim: no recoverable old sessions matched the trim rules.")
        return
    for idx, item in enumerate(planned, start=1):
        workspace = item["workspace"]
        selected = item["selected"]
        status = statuses[idx - 1] if idx - 1 < len(statuses) else action
        title = workspace.get("workspace_title") or "(no title)"
        print(
            f"{idx}. {status}\t{format_mb(item.get('rss_kb'))}\tage={format_age(item.get('age_seconds') or 0)}\t"
            f"{selected.get('tool')}\tsession={selected.get('session_id')}\tlast={selected.get('last_seen')}\t"
            f"{workspace.get('workspace_ref') or workspace.get('workspace_id')}\t"
            f"{workspace.get('surface_ref') or workspace.get('surface_id')}\t{title}"
        )
    if not args.execute:
        print("trim: dry run only. Add --execute to stop these agents and leave the tabs ready for cmr.")


def cmd_trim(args: argparse.Namespace) -> int:
    if args.limit < 1:
        print("trim: --limit must be at least 1")
        return 2
    with connect_db() as con:
        if args.no_snapshot:
            samples = latest_memory_samples(con)
        else:
            rows = tree_workspaces()
            insert_workspace_observations(con, args.source, rows)
            samples = record_memory_snapshot(con, args.source, rows, force=True)
        total_rss_kb, target_rss_kb, candidates, skipped = trim_candidate_rows(con, samples, args)
        planned, projected_rss_kb = plan_trim(args, total_rss_kb, target_rss_kb, candidates)
        statuses: list[str] = []
        stopped_count = 0
        if args.execute:
            for item in planned:
                ok = stop_trim_item(item, args.method)
                statuses.append("stopped" if ok else "failed")
                if ok:
                    stopped_count += 1
        log_trim(
            con,
            action="trim-execute" if args.execute else "trim-dry-run",
            status="executed" if args.execute else "dry-run",
            method=args.method,
            total_rss_kb=total_rss_kb,
            target_rss_kb=target_rss_kb,
            projected_rss_kb=projected_rss_kb,
            candidates=candidates,
            planned=planned,
            stopped_count=stopped_count,
            skipped=skipped,
        )
        export_latest(con)
        con.commit()
    print_trim_report(
        args=args,
        total_rss_kb=total_rss_kb,
        target_rss_kb=target_rss_kb,
        projected_rss_kb=projected_rss_kb,
        candidates=candidates,
        planned=planned,
        statuses=statuses,
    )
    return 0


def default_codex_state_path() -> Path:
    return Path(os.environ.get("CMUX_CODEX_STATE", "~/.codex/state_5.sqlite")).expanduser()


def refresh_codex_state(con: sqlite3.Connection) -> int:
    return import_codex_state(con, default_codex_state_path())


def cmd_recover(args: argparse.Namespace) -> int:
    action = "recover-dry-run" if args.dry_run else "recover"
    with connect_db() as con:
        codex_imported = refresh_codex_state(con)
        rows = tree_workspaces()
        insert_workspace_observations(con, "recover", rows)
        record_memory_snapshot(con, "recover", rows)
        current = current_workspace()
        current["codex_state_imported"] = codex_imported
        if not current.get("current_directory"):
            current["current_directory"] = str(DEFAULT_RESTORE_CWD)
        if not current.get("normalized_title"):
            current["normalized_title"] = normalize_title(current.get("workspace_title"))
        current["screen_text"] = read_screen_text(current)
        current["screen_resume_refs"] = screen_resume_refs_from_text(current["screen_text"])
        candidates = load_candidates(con, current)
        status, selected = choose_candidate(args, candidates)
        debug_path = write_recover_debug_log(
            action=action,
            status=status,
            current=current,
            selected=selected,
            candidates=candidates,
            choice=args.choice,
            dry_run=args.dry_run,
        )
        log_restore(con, action, status, current, selected, candidates, debug_path)
        con.commit()

    if status == "missing":
        print(f"cmr: no recoverable Claude/Codex session found for workspace {workspace_label(current)!r}.")
        print(f"cmr: debug log {debug_path}")
        return 2
    if status == "ambiguous":
        if len(candidates) == 1:
            print(f"cmr: possible session found for workspace {workspace_label(current)!r}. Pick it with `cmr 1`:")
        else:
            print(f"cmr: multiple possible sessions found for workspace {workspace_label(current)!r}. Pick one with `cmr N`:")
        print_candidates(candidates)
        print(f"cmr: debug log {debug_path}")
        return 3
    if status == "invalid-choice":
        print(f"cmr: invalid choice for workspace {workspace_label(current)!r}. Current candidates:")
        print_candidates(candidates)
        print(f"cmr: debug log {debug_path}")
        return 4

    assert selected is not None
    command = selected["command"]
    if args.debug:
        print(f"cmr: debug log {debug_path}")
    if args.dry_run:
        print(command)
        return 0

    cwd = str(candidate_cwd(selected))
    topic = ""
    if selected.get("topic_relevance") or selected.get("topic_penalty"):
        topic = f" topic=+{int(selected.get('topic_relevance') or 0)}/-{int(selected.get('topic_penalty') or 0)}"
    print(
        f"cmr: selected {selected.get('tool')} session={selected.get('session_id')} "
        f"score={selected.get('score')}{topic}"
    )
    sys.stdout.flush()
    os.chdir(cwd)
    if selected["tool"] == "codex":
        os.execvp("codex", ["codex", "-C", cwd, "resume", selected["session_id"]])
    os.execvp("claude", ["claude", "--resume", selected["session_id"]])
    return 0


def cmd_verify(args: argparse.Namespace) -> int:
    with connect_db() as con:
        refresh_codex_state(con)
        rows = tree_workspaces()
        insert_workspace_observations(con, "verify", rows)
        record_memory_snapshot(con, "verify", rows)
        chooser_args = argparse.Namespace(choice=None)
        for ws in rows:
            if not ws.get("current_directory"):
                ws["current_directory"] = str(DEFAULT_RESTORE_CWD)
            candidates = load_candidates(con, ws)
            status, selected = choose_candidate(chooser_args, candidates)
            status = "exact" if status == "selected" else status
            top = selected or (candidates[0] if candidates else None)
            print(
                f"{ws.get('workspace_index', '')}\t{status}\t{ws.get('workspace_title') or ''}\t"
                f"{top.get('tool') if top else ''}\t{top.get('session_id') if top else ''}\t"
                f"{top.get('last_seen') if top else ''}\t{top.get('score') if top else ''}"
            )
    return 0


def record_imported_session(
    con: sqlite3.Connection,
    *,
    source: str,
    observed_at: str,
    tool: str | None,
    session_id: str | None,
    title: str | None = None,
    cwd: str | None = None,
    workspace_index: int | None = None,
    workspace_id: str | None = None,
    workspace_ref: str | None = None,
    surface_id: str | None = None,
    surface_ref: str | None = None,
    command: str | None = None,
) -> bool:
    if tool not in {"claude", "codex"} or not session_id:
        return False
    row = {
        "observed_at": observed_at,
        "tool": tool,
        "event": source,
        "source": source,
        "session_id": session_id,
        "turn_id": None,
        "cwd": cwd,
        "transcript_path": None,
        "model": None,
        "permission_mode": None,
        "workspace_title": title,
        "normalized_title": normalize_title(title),
        "workspace_id": workspace_id,
        "workspace_ref": workspace_ref,
        "workspace_index": workspace_index,
        "surface_id": surface_id,
        "surface_ref": surface_ref,
        "tab_id": surface_id,
        "pane_id": None,
        "process_title": None,
        "tty": None,
        "payload_json": json.dumps({"command": command} if command else {}, separators=(",", ":"), ensure_ascii=False),
    }
    upsert_event(con, row)
    return True


def import_legacy_ledger(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    count = 0
    with path.open("r", encoding="utf-8", newline="") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for raw in reader:
            source = raw.get("source") or "legacy-ledger"
            tool = "codex" if "codex" in source else "claude" if "claude" in source else None
            if not tool or not raw.get("session_id"):
                continue
            row = {
                "observed_at": raw.get("timestamp_utc") or utc_now(),
                "tool": tool,
                "event": raw.get("event") or source,
                "source": source,
                "session_id": raw.get("session_id"),
                "turn_id": None,
                "cwd": raw.get("payload_cwd") or raw.get("pwd"),
                "transcript_path": raw.get("transcript_path"),
                "model": None,
                "permission_mode": None,
                "workspace_title": raw.get("workspace_name") if raw.get("workspace_name") != "unknown" else None,
                "normalized_title": normalize_title(raw.get("workspace_name") if raw.get("workspace_name") != "unknown" else None),
                "workspace_id": raw.get("cmux_workspace_id"),
                "workspace_ref": raw.get("workspace_ref"),
                "workspace_index": None,
                "surface_id": raw.get("cmux_surface_id"),
                "surface_ref": None,
                "tab_id": raw.get("cmux_tab_id"),
                "pane_id": None,
                "process_title": None,
                "tty": None,
                "payload_json": "{}",
            }
            upsert_event(con, row)
            count += 1
    return count


def import_restore_manifest(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    observed_at = file_observed_at(path)
    count = 0
    with path.open("r", encoding="utf-8", newline="") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for raw in reader:
            command = clean(raw.get("best_resume_command"))
            if record_imported_session(
                con,
                source=f"restore-manifest:{path.name}",
                observed_at=observed_at,
                tool=tool_from_label(raw.get("best_tool")),
                session_id=clean(raw.get("best_session_id")) or extract_session_id(command),
                title=clean(raw.get("title")),
                cwd=clean(raw.get("current_directory")),
                workspace_index=int_or_none(raw.get("index")),
                surface_id=clean(raw.get("current_surface_id")),
                command=command,
            ):
                count += 1
    return count


def import_tab_inventory(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    observed_at = file_observed_at(path)
    count = 0
    with path.open("r", encoding="utf-8", newline="") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for raw in reader:
            command = clean(raw.get("best_resume_command"))
            if record_imported_session(
                con,
                source=f"tab-inventory:{path.name}",
                observed_at=observed_at,
                tool=tool_from_label(raw.get("best_tool")),
                session_id=clean(raw.get("best_session_id")) or extract_session_id(command),
                title=clean(raw.get("title")),
                cwd=clean(raw.get("current_directory") or raw.get("precrash_directory")),
                workspace_index=int_or_none(raw.get("index")),
                surface_id=clean(raw.get("current_surface_id") or raw.get("precrash_surface_id")),
                command=command,
            ):
                count += 1
    return count


def import_current_audit(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    observed_at = file_observed_at(path)
    count = 0
    with path.open("r", encoding="utf-8", newline="") as f:
        reader = csv.reader(f, delimiter="\t")
        for raw in reader:
            if len(raw) < 11:
                continue
            index, _status, _expected_tool, best_tool, title, workspace_ref, surface_ref, surface_id, session_id, _pid, cwd = raw[:11]
            if record_imported_session(
                con,
                source=f"current-audit:{path.name}",
                observed_at=observed_at,
                tool=tool_from_label(best_tool),
                session_id=clean(session_id),
                title=clean(title),
                cwd=clean(cwd),
                workspace_index=int_or_none(index),
                workspace_ref=clean(workspace_ref),
                surface_ref=clean(surface_ref),
                surface_id=clean(surface_id),
            ):
                count += 1
    return count


def import_old_sessions_backup(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    observed_at = file_observed_at(path)
    count = 0
    with path.open("r", encoding="utf-8", newline="") as f:
        reader = csv.reader(f, delimiter="\t")
        for raw in reader:
            if len(raw) < 4:
                continue
            title, cwd, tool_label, command = raw[:4]
            if record_imported_session(
                con,
                source=f"old-sessions-backup:{path.name}",
                observed_at=observed_at,
                tool=tool_from_label(tool_label),
                session_id=extract_session_id(command),
                title=clean(title),
                cwd=clean(cwd),
                command=clean(command),
            ):
                count += 1
    return count


def import_known_reports(con: sqlite3.Connection, report_dirs: list[Path]) -> dict[str, int]:
    counts = {
        "restore_manifest": 0,
        "tab_inventory": 0,
        "current_audit": 0,
        "old_backup": 0,
    }
    for directory in report_dirs:
        counts["restore_manifest"] += import_restore_manifest(con, directory / "cmux-restore-armed.latest.tsv")
        counts["tab_inventory"] += import_tab_inventory(con, directory / "cmux-tab-id-inventory.tsv")
        counts["current_audit"] += import_current_audit(con, directory / "current-audit.tsv")
        counts["old_backup"] += import_old_sessions_backup(con, directory / "old-cmux-sessions-backup-parsed.tsv")
    return counts


def import_codex_state(con: sqlite3.Connection, path: Path) -> int:
    if not path.exists():
        return 0
    try:
        src = sqlite3.connect(f"file:{path}?mode=ro", uri=True)
        src.row_factory = sqlite3.Row
    except sqlite3.Error:
        return 0
    count = 0
    try:
        for row in src.execute(
            """
            SELECT id, updated_at, cwd, rollout_path, title, model, approval_mode, sandbox_policy
            FROM threads
            WHERE archived = 0
            ORDER BY updated_at DESC
            LIMIT 2000
            """
        ):
            observed = dt.datetime.fromtimestamp(int(row["updated_at"]), dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
            event = {
                "observed_at": observed,
                "tool": "codex",
                "event": "codex-state-import",
                "source": "codex-state",
                "session_id": row["id"],
                "turn_id": None,
                "cwd": row["cwd"],
                "transcript_path": row["rollout_path"],
                "model": row["model"],
                "permission_mode": row["approval_mode"],
                "workspace_title": None,
                "normalized_title": None,
                "workspace_id": None,
                "workspace_ref": None,
                "workspace_index": None,
                "surface_id": None,
                "surface_ref": None,
                "tab_id": None,
                "pane_id": None,
                "process_title": row["title"],
                "tty": None,
                "payload_json": "{}",
            }
            upsert_event(con, event)
            count += 1
    except sqlite3.Error:
        pass
    finally:
        src.close()
    return count


def cmd_import_legacy(args: argparse.Namespace) -> int:
    with connect_db() as con:
        ledger_count = import_legacy_ledger(con, Path(args.ledger).expanduser())
        report_dirs = [Path(value).expanduser() for value in args.report_dir] if args.report_dir else default_report_dirs()
        report_counts = import_known_reports(con, report_dirs)
        codex_count = import_codex_state(con, Path(args.codex_state).expanduser())
        export_latest(con)
    report_summary = " ".join(f"{key}={value}" for key, value in report_counts.items())
    print(f"imported: ledger={ledger_count} {report_summary} codex_state={codex_count}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="cmux-recovery")
    sub = parser.add_subparsers(dest="command", required=True)

    record = sub.add_parser("record")
    record.add_argument("--tool", required=True, choices=["claude", "codex"])
    record.add_argument("--event")
    record.add_argument("--source")
    record.add_argument("--cwd")
    record.set_defaults(func=cmd_record)

    resume = sub.add_parser("record-resume")
    resume.add_argument("--tool", required=True, choices=["claude", "codex"])
    resume.add_argument("--session-id", required=True)
    resume.add_argument("--event", default="resume-command")
    resume.add_argument("--source")
    resume.add_argument("--cwd")
    resume.set_defaults(func=cmd_record_resume)

    pin = sub.add_parser("pin")
    pin.add_argument("--title")
    pin.add_argument("--tool", required=True, choices=["claude", "codex"])
    pin.add_argument("--session-id", required=True)
    pin.add_argument("--cwd")
    pin.add_argument("--note")
    pin.set_defaults(func=cmd_pin)

    ignore = sub.add_parser("ignore")
    ignore.add_argument("--tool", required=True, choices=["claude", "codex"])
    ignore.add_argument("--session-id", required=True)
    ignore.add_argument("--reason")
    ignore.set_defaults(func=cmd_ignore)

    snapshot = sub.add_parser("snapshot")
    snapshot.add_argument("--source", default="manual-snapshot")
    snapshot.add_argument("--quiet", action="store_true")
    snapshot.set_defaults(func=cmd_snapshot)

    memory_snapshot = sub.add_parser("memory-snapshot")
    memory_snapshot.add_argument("--source", default="manual-memory-snapshot")
    memory_snapshot.add_argument("--quiet", action="store_true")
    memory_snapshot.add_argument("--limit", type=int, default=10)
    memory_snapshot.set_defaults(func=cmd_memory_snapshot)

    memory_top = sub.add_parser("memory-top")
    memory_top.add_argument("--since", default="6h")
    memory_top.add_argument("--limit", type=int, default=15)
    memory_top.set_defaults(func=cmd_memory_top)

    memory_list = sub.add_parser("memory-list")
    memory_list.add_argument("--limit", type=int)
    memory_list.add_argument("--quiet", action="store_true")
    memory_list.set_defaults(func=cmd_memory_list)

    sidebar_metrics = sub.add_parser("sidebar-metrics")
    sidebar_metrics.add_argument("--execute", action="store_true")
    sidebar_metrics.add_argument("--clear", action="store_true")
    sidebar_metrics.add_argument("--limit", type=int, default=12)
    sidebar_metrics.add_argument("--source", default="sidebar-metrics")
    sidebar_metrics.set_defaults(func=cmd_sidebar_metrics)

    trim = sub.add_parser("trim")
    trim.add_argument("--target-gb", type=float, default=30.0)
    trim.add_argument("--min-mb", type=float, default=128.0)
    trim.add_argument("--min-age", default="30m")
    trim.add_argument("--limit", type=int, default=10)
    trim.add_argument("--method", choices=["respawn", "ctrl-c"], default="respawn")
    trim.add_argument("--execute", action="store_true")
    trim.add_argument("--force", action="store_true")
    trim.add_argument("--include-active", action="store_true")
    trim.add_argument("--no-snapshot", action="store_true")
    trim.add_argument("--source", default="trim")
    trim.set_defaults(func=cmd_trim)

    recover = sub.add_parser("recover")
    recover.add_argument("choice", nargs="?", type=int)
    recover.add_argument("--dry-run", action="store_true")
    recover.add_argument("--debug", action="store_true")
    recover.set_defaults(func=cmd_recover)

    verify = sub.add_parser("verify")
    verify.set_defaults(func=cmd_verify)

    legacy = sub.add_parser("import-legacy")
    legacy.add_argument("--ledger", default=os.environ.get("CMUX_RECOVERY_LEDGER", "~/.cmux-agent-recovery/session-ledger.tsv"))
    legacy.add_argument("--codex-state", default=os.environ.get("CMUX_CODEX_STATE", "~/.codex/state_5.sqlite"))
    legacy.add_argument("--report-dir", action="append")
    legacy.set_defaults(func=cmd_import_legacy)
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
