}
GENERIC_WORKFLOW_MARKERS = (
    "linkedin outreach agent",
    "linkedin engagement agent",
    "linkedin content creation agent",
    "linkedin content metrics agent",
    "accept incoming connection requests",
    "combined inbox check",
    "reply to active conversations",
